# Terraform local state and init artifacts — never commit these
**/.terraform/
**/.terraform.lock.hcl
*.tfplan
*.tfplan.json
tfplan

# Sensitive variable files
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
